APP_ENV=production
PORT=8000
DATABASE_URL_FILE=/run/secrets/treseko_database_url
SECRET_KEY_FILE=/run/secrets/treseko_secret_key
ENGINE_URL=http://engine:3010
REDIS_URL=redis://redis:6379/0

# No habilitar flags TRESEKO_ALLOW_DEV_* en produccion.
# No guardar DATABASE_URL ni SECRET_KEY inline en archivos productivos.
# Los keyrings publicos oficiales se embeben en el build de release.
