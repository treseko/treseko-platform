# Treseko Community self-hosted release
APP_ENV=production
TRESEKO_HTTP_PORT=8080

# Obligatorio: generar valores propios antes de publicar.
# Este archivo solo guarda rutas. Los secretos reales viven fuera del repo.
DB_USER=treseko
DB_NAME=treseko
TRESEKO_DB_PASSWORD_FILE=/opt/treseko/secrets/db-password
TRESEKO_DATABASE_URL_FILE=/opt/treseko/secrets/database-url
TRESEKO_SECRET_KEY_FILE=/opt/treseko/secrets/secret-key
CORS_ALLOWED_ORIGINS=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30
LOG_LEVEL=INFO

# Opcional: motor IA compatible con OpenAI.
AI_API_ENDPOINT=
AI_MODEL=
QA_TEST_TRACE_ENABLED=false

# Opcional: worker local emparejado desde la UI de Automatizacion.
# Sin RUNNER_TOKEN valido no levantes el profile automation.
# No guardar RUNNER_TOKEN en este archivo base; exportarlo solo al arrancar
# el profile automation o cargarlo desde un archivo local no versionado.
WORKER_POLL_INTERVAL_MS=5000

# Actualizaciones: en produccion se espeja el historial JSON en PostgreSQL
# para auditoria transaccional. En dev/tests queda apagado por defecto.
TRESEKO_UPDATE_DB_HISTORY_ENABLED=true
TRESEKO_UPDATE_STEP_TIMEOUT_SECONDS=300
# Canal publico de actualizaciones Community.
# Usuarios finales: dejar community-stable.
# Pruebas internas: community-smoke o community-beta.
TRESEKO_COMMUNITY_UPDATE_CHANNEL=community-stable
